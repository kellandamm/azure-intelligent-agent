# ============================================================================
# Authentication & Database Configuration
# ============================================================================

# Enable/Disable Authentication (set to false to bypass authentication)
ENABLE_AUTHENTICATION=true

# Database Connection (Microsoft Fabric SQL Database or Azure SQL)
# REQUIRED: Replace with your database server details
SQL_SERVER=<your-sql-server>.database.windows.net
SQL_DATABASE=<your-database-name>
SQL_USERNAME=  # Optional if using Azure AD authentication
SQL_PASSWORD=  # Optional if using Azure AD authentication
SQL_DRIVER=ODBC Driver 18 for SQL Server
SQL_USE_AZURE_AUTH=true  # Use Azure AD authentication
SQL_ENCRYPT=true
SQL_TRUST_SERVER_CERT=false

# JWT Configuration (Generate a secure random string for production)
# You can generate one with: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRY_HOURS=24

# ============================================================================
# Microsoft AI Foundry Configuration (Required)
# ============================================================================
# Microsoft AI Foundry is the primary agent backend for this application

# Azure AI Foundry Project Endpoint
# Find in: AI Foundry portal → Project → Settings → Endpoint
# Format: https://<resource>.services.ai.azure.com/api/projects/<project-name>
PROJECT_ENDPOINT=https://<your-resource>.services.ai.azure.com/api/projects/<your-project>

# Model deployment name in your AI Foundry project
MODEL_DEPLOYMENT_NAME=gpt-4o  # or gpt-5.2

# Agent Backend Selection (Default: Microsoft AI Foundry)
USE_FOUNDRY_AGENTS=true  # Set to false to use code-based agent backend
# Enable published Agent Applications (Responses protocol)
USE_PUBLISHED_AGENT_APPLICATIONS=false

# ============================================================================
# Azure OpenAI Configuration (Optional - only if not using Foundry models)
# ============================================================================
# Leave these empty to use Foundry's built-in models (recommended)
# Only fill if you need a separate Azure OpenAI resource

AZURE_OPENAI_ENDPOINT=  # https://<your-openai-resource>.openai.azure.com/
AZURE_OPENAI_DEPLOYMENT=  # e.g., gpt-4o, gpt-4, gpt-35-turbo
AZURE_OPENAI_API_VERSION=2024-08-01-preview

# Microsoft Fabric Configuration (data platform)
FABRIC_WORKSPACE_ID=your-workspace-id
FABRIC_CONNECTION_ID=

# Azure AI Foundry Agent IDs (set these after creating agents in the Foundry portal)
ORCHESTRATOR_AGENT_ID=<your-orchestrator-agent-id>
ORCHESTRATOR_AGENT_NAME=RetailAssistantOrchestrator
SALES_AGENT_ID=<your-sales-agent-id>
REALTIME_AGENT_ID=<your-realtime-agent-id>
ANALYTICS_AGENT_ID=<your-analytics-agent-id>
FINANCIAL_AGENT_ID=<your-financial-agent-id>
SUPPORT_AGENT_ID=<your-support-agent-id>
OPERATIONS_AGENT_ID=<your-operations-coordinator-agent-id>
CUSTOMER_SUCCESS_AGENT_ID=<your-customer-success-agent-id>
OPERATIONS_EXCELLENCE_AGENT_ID=<your-operations-excellence-agent-id>

# Published Agent Application names (used when USE_PUBLISHED_AGENT_APPLICATIONS=true)
ORCHESTRATOR_AGENT_APP_NAME=RetailAssistantOrchestrator
SALES_AGENT_APP_NAME=SalesAssistant
REALTIME_AGENT_APP_NAME=OperationsAssistant
ANALYTICS_AGENT_APP_NAME=AnalyticsAssistant
FINANCIAL_AGENT_APP_NAME=FinancialAdvisor
SUPPORT_AGENT_APP_NAME=CustomerSupportAssistant
OPERATIONS_AGENT_APP_NAME=OperationsCoordinator
CUSTOMER_SUCCESS_AGENT_APP_NAME=CustomerSuccessAgent
OPERATIONS_EXCELLENCE_AGENT_APP_NAME=OperationsExcellenceAgent

# Power BI Integration Configuration
POWERBI_WORKSPACE_ID=your-powerbi-workspace-id
POWERBI_WORKSPACE_NAME=
POWERBI_REPORT_ID=
POWERBI_CLIENT_ID=
POWERBI_CLIENT_SECRET=
POWERBI_TENANT_ID=your-tenant-id
POWERBI_CONNECTION_URL=

# Azure Deployment - REQUIRED: Replace with your Azure resource names
AZURE_SUBSCRIPTION_ID=<your-subscription-id>
AZURE_RESOURCE_GROUP=<your-resource-group-name>
AZURE_LOCATION=<your-azure-region>  # e.g., eastus2, westus, westeurope
AZURE_CONTAINER_REGISTRY=<your-acr-name>  # ACR name without .azurecr.io
AZURE_APP_NAME=<your-app-service-name>  # App Service name
APPLICATION_INSIGHTS_NAME=<your-app-insights-name>

# Application Configuration
APP_PORT=8080
LOG_LEVEL=INFO
ENABLE_TRACING=true

# ============================================================================
# Fabric SQL Analytics Configuration (Optional)
# ============================================================================
# Configure these to query Fabric lakehouse data via SQL analytics endpoint
# Find in Fabric: Workspace → Settings → SQL analytics endpoint

FABRIC_SQL_SERVER=  # e.g., xyz-abc123.datawarehouse.fabric.microsoft.com
FABRIC_SQL_DATABASE=  # e.g., MyLakehouse
FABRIC_CLIENT_ID=  # Service principal for Fabric SQL (can reuse Power BI SP)
FABRIC_CLIENT_SECRET=  # Service principal secret
FABRIC_TENANT_ID=  # Optional, defaults to POWERBI_TENANT_ID if not set
FABRIC_SQL_USE_AZURE_AUTH=true  # Use Azure AD authentication
FABRIC_SQL_ENCRYPT=true
FABRIC_SQL_TRUST_SERVER_CERT=false
FABRIC_SQL_DRIVER=ODBC Driver 18 for SQL Server
