# Base runtime settings
ANALYTICS_MODE=sql
CHAT_BACKEND_MODE=standard
USE_FOUNDRY_AGENTS=false

# Optional SQL / app settings
SQL_CONNECTION_STRING=

# Optional Foundry + Fabric settings, only required when CHAT_BACKEND_MODE=foundry
FOUNDRY_PROJECT_ENDPOINT=
PROJECT_ENDPOINT=
FABRIC_PROJECT_CONNECTION_NAME=
FOUNDRY_MODEL_DEPLOYMENT_NAME=

# Optional Fabric profile flags
ENABLE_FABRIC=false
ENABLE_DIRECT_LAKE=true
ENABLE_FABRIC_RTI=false

# Optional governance profile flags
ENABLE_PURVIEW=false
PURVIEW_ACCOUNT_NAME=
